{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "linup-io",
  "version": "0.1.0",
  "identifier": "io.linup.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "linup-io",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
    "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2NzlDNzc5OTU4OUM1QTkKUldTcHhZbVZlY2Q1eG52clR6QmNKZ2tGVzZtMXg0Q0YzUWpWQ3hjcmIzY2NYNVR3cUdmc1d3b1IK",
      "endpoints": ["https://linup.io/updates/{{target}}/{{arch}}/{{current_version}}"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}